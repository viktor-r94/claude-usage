{
  "name": "claude-usage",
  "version": "1.1.0",
  "description": "A tiny macOS menu bar app showing your Claude.ai plan usage.",
  "main": "src/main.js",
  "author": "Viktor Rizak",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --dir",
    "test": "jest"
  },
  "build": {
    "appId": "com.viktorrizak.claude-usage",
    "productName": "Claude Usage",
    "mac": {
      "category": "public.app-category.utilities",
      "target": {
        "target": "dir",
        "arch": [
          "arm64"
        ]
      }
    },
    "files": [
      "src/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "jest": "^30.4.2"
  }
}
